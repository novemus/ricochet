@PACKAGE_INIT@

macro(import_targets type)
    if(NOT EXISTS "${CMAKE_CURRENT_LIST_DIR}/ricochet-${type}-targets.cmake")
        set(${CMAKE_FIND_PACKAGE_NAME}_NOT_FOUND_MESSAGE "ricochet ${type} libraries were requested but not found")
        set(${CMAKE_FIND_PACKAGE_NAME}_FOUND OFF)
        return()
    endif()

    include("${CMAKE_CURRENT_LIST_DIR}/ricochet-${type}-targets.cmake")
endmacro()

if(NOT TARGET ricochet::libricochet)
    set(_type "")

    if(DEFINED RICOCHET_USE_SHARED_LIB)
        if(RICOCHET_USE_SHARED_LIB)
            set(_type "shared")
        else()
            set(_type "static")
        endif()
    elseif(BUILD_SHARED_LIBS AND EXISTS "${CMAKE_CURRENT_LIST_DIR}/ricochet-shared-targets.cmake")
        set(_type "shared")
    elseif(EXISTS "${CMAKE_CURRENT_LIST_DIR}/ricochet-static-targets.cmake")
        set(_type "static")
    else()
        set(_type "shared")
    endif()

    import_targets(${_type})
    check_required_components(ricochet)

    include(CMakeFindDependencyMacro)

    get_target_property(ricochet_INCLUDE_DIRS ricochet::libricochet INTERFACE_INCLUDE_DIRECTORIES)
    set(ricochet_LIBRARY ricochet::libricochet)

    set(ricochet_FOUND ON)
    unset(_type)
endif()
